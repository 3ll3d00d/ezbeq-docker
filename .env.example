# Copy this file to .env and fill in the values.
# .env is git-ignored so your local settings won't be committed.

# Path to your local ezbeq source tree / worktree (required)
EZBEQ_SRC=/path/to/ezbeq

# Path to your ezbeq.yml config file (default: ~/.ezbeq/ezbeq.yml)
# EZBEQ_CONFIG=/Users/you/.ezbeq/ezbeq.yml

# Port to expose locally (default: 8080)
# EZBEQ_PORT=8080
